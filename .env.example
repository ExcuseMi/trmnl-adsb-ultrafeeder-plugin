# Ultrafeeder base URL (reachable within your Docker network)
ULTRAFEEDER_URL=http://ultrafeeder

# Feeder station coordinates (used for distance calculation and radar centre)
FEEDER_LAT=51.1234
FEEDER_LON=4.5678

# TRMNL webhook URL — copy from the plugin settings page
TRMNL_WEBHOOK_URL=https://trmnl.com/api/custom_plugins/YOUR_PLUGIN_UUID

# Payload tier: standard (2 KB) or plus (5 KB)
TIER=standard

# Polling interval in seconds (300 = 5 min, safe for standard tier 12/hr limit)
POLL_INTERVAL_SECONDS=300

# Include position trails for closest planes
TRAILS_ENABLED=true

# Rolling history depth: 1h, 2h, 3h, 6h, 12h, 24h
HISTORY_TIMEFRAME=2h

# Route label style: codes (LHR>AMS), cities (LONDON>AMSTERDAM), off
ROUTE_DISPLAY=codes
# Path inside the container for persisting history across restarts
STATE_PATH=/data/state.json

# Note: radar center position is set via the plugin settings UI in the TRMNL dashboard
# (Radar Center Latitude / Radar Center Longitude), not via env vars.
